# ============================================
# Clinic Appointment System — Environment Variables Template
# ============================================

# ---- PostgreSQL ----
POSTGRES_USER=clinic_admin
POSTGRES_PASSWORD=CHANGE_ME_strong_password
POSTGRES_DB=clinic_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql://clinic_admin:CHANGE_ME_strong_password@postgres:5432/clinic_db

# ---- JWT ----
JWT_SECRET_KEY=CHANGE_ME_random_256bit_key
JWT_EXPIRY_HOURS=1

# ---- RabbitMQ ----
RABBITMQ_USER=clinic_rmq
RABBITMQ_PASS=CHANGE_ME_strong_password
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_URL=amqp://clinic_rmq:CHANGE_ME_strong_password@rabbitmq:5672/

# ---- Internal API Key (Service-to-Service) ----
INTERNAL_API_KEY=CHANGE_ME_random_key

# ---- File Encryption (Fernet Key) ----
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=CHANGE_ME_fernet_key

# ---- GitHub OAuth ----
# 1. Go to https://github.com/settings/developers
# 2. Click "New OAuth App"
# 3. Set Authorization callback URL to: https://localhost/api/auth/oauth/github/callback
# 4. Copy Client ID and Client Secret below
GITHUB_CLIENT_ID=your_github_client_id_here
GITHUB_CLIENT_SECRET=your_github_client_secret_here

# ---- Service URLs (internal) ----
AUTH_SERVICE_URL=http://auth-service:5000
APPOINTMENT_SERVICE_URL=http://bussiness-service-1:5001
NOTIFICATION_SERVICE_URL=http://business-service-2:5002
LOGGING_SERVICE_URL=http://logging-service:5003
